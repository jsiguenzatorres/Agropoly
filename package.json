{
  "name": "agropoly-apex",
  "private": true,
  "version": "1.0.0",
  "description": "AGROPOLY BFA — Juego de mesa digital del Banco de Fomento Agropecuario de El Salvador",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "pnpm --filter @agropoly/server supabase db push",
    "db:types": "pnpm --filter @agropoly/server supabase gen types"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.1",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.0"
}
