# ════════════════════════════════════════════════════════
#  AGROPOLY APEX — Variables de Entorno
#  Copiar a .env y completar los valores reales
#  NUNCA commitear el .env con valores reales
# ════════════════════════════════════════════════════════

# ── SUPABASE ──────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Solo en servidor, NUNCA en cliente
SUPABASE_ACCESS_TOKEN=sbp_...      # Para CLI de Supabase

# ── CLAUDE / ANTHROPIC ───────────────────────────────
# Solo en servidor o Edge Functions de Supabase
# NUNCA en variables VITE_ del cliente frontend
ANTHROPIC_API_KEY=sk-ant-...

# ── ELEVENLABS ────────────────────────────────────────
# Solo en servidor
ELEVENLABS_API_KEY=...

# Voice IDs (clonar de actores salvadoreños reales)
ELEVENLABS_VOICE_DON_FOMENTO=vf-don-fomento-xxxx
ELEVENLABS_VOICE_MAICITA=vf-maicita-xxxx
ELEVENLABS_VOICE_DON_CAFE=vf-don-cafe-xxxx
ELEVENLABS_VOICE_LA_CANCHE=vf-la-canche-xxxx
ELEVENLABS_VOICE_LA_VAQUITA=vf-la-vaquita-bfa-xxxx
ELEVENLABS_VOICE_LA_TORMENTA=vf-la-tormenta-xxxx

# ── REDIS (Upstash) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── GITHUB ────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── FIGMA ─────────────────────────────────────────────
FIGMA_API_KEY=figd_...

# ── VERCEL ────────────────────────────────────────────
VERCEL_TOKEN=...

# ── SENTRY ────────────────────────────────────────────
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_DSN=https://...@sentry.io/...

# ── BRAVE SEARCH ──────────────────────────────────────
BRAVE_API_KEY=BSA...

# ── COLYSEUS ──────────────────────────────────────────
COLYSEUS_PORT=2567
COLYSEUS_SECRET=change-me-in-production

# ── FRONTEND (VITE_ prefix — visible en cliente) ──────
# Solo poner aquí lo que puede ser público
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_COLYSEUS_URL=ws://localhost:2567
VITE_SENTRY_DSN=https://...@sentry.io/...
